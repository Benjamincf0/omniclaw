# Shared runtime configuration for `./omniclaw up`

# Required by the orchestrator
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Required by the Discord bot
DISCORD_BOT_TOKEN=

# Optional shared overrides
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8080
ORCHESTRATOR_URL=http://127.0.0.1:8080

MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_TRANSPORT_PATH=/mcp
MCP_SERVER_URLS=omnivox=http://127.0.0.1:8000/mcp

# Optional model/provider overrides
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TEMPERATURE=0.2

# Optional Discord behavior
# DISCORD_REQUIRE_MENTION=true
# DISCORD_ALLOW_DMS=true
# DISCORD_CHANNEL_IDS=
# DISCORD_COMMAND_GUILD_IDS=

# Optional legacy MCP chat endpoint.
# This is not required for the Discord + orchestrator stack.
# GEMINI_API_KEY=
